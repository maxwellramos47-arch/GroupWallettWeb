datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Planes_Suscripcion {
  id_plan       Int        @id @default(autoincrement())
  nombre_plan   String
  precio        Decimal    @db.Decimal(10, 2)
  limite_grupos Int
  beneficios    String?    @db.Text
  usuarios      Usuarios[]

  @@map("planes_suscripcion")
}

model Usuarios {
  id_usuario                    Int       @id @default(autoincrement())
  nombre                        String
  correo                        String    @unique
  telefono                      String?   @db.Text
  password_hash                 String
  fecha_registro                DateTime? @default(now())
  id_plan                       Int?      @default(1)
  estado_suscripcion            String?   @default("activo")
  fecha_vencimiento_suscripcion DateTime? @db.Date
  reset_token                   String?
  reset_token_expires           DateTime? @db.Timestamp()
  intentos_fallidos             Int?      @default(0)
  bloqueado_hasta               DateTime? @db.Timestamp()
  foto_url                      String?
  push_subscription             String?   @db.Text
  fecha_revocacion_sesiones     DateTime? @db.Timestamp()
  telefono_verificado           Boolean?  @default(false)
  codigo_verificacion_telefono  String?
  codigo_verificacion_expires   DateTime? @db.Timestamp()
  reenvio_codigo_intentos       Int?      @default(0)
  reenvio_codigo_bloqueado_hasta DateTime? @db.Timestamp()
  recuperacion_intentos         Int?      @default(0)
  recuperacion_bloqueado_hasta  DateTime? @db.Timestamp()

  plan                          Planes_Suscripcion? @relation(fields: [id_plan], references: [id_plan])
  grupos_creados                Grupos[]
  membresias                    Miembros_Grupo[]
  transacciones_pagadas         Transacciones[]
  transacciones_participa       Transaccion_Participantes[]
  metodos_pago                  Metodos_Pago[]
  datos_bancarios               Datos_Bancarios?
  pagos_inapp_emitidos          Pagos_InApp[] @relation("Pagador")
  pagos_inapp_recibidos         Pagos_InApp[] @relation("Receptor")
  sesiones_activas              Sesiones_Activas[]

  @@index([id_plan, estado_suscripcion])
  @@index([fecha_registro, id_plan])
  @@map("usuarios")
}

model Grupos {
  id_grupo           Int       @id @default(autoincrement())
  nombre_grupo       String
  id_usuario_creador Int
  fecha_creacion     DateTime? @default(now()) @db.Timestamp()

  creador            Usuarios  @relation(fields: [id_usuario_creador], references: [id_usuario])
  miembros           Miembros_Grupo[]
  transacciones      Transacciones[]

  @@map("grupos")
}

model Miembros_Grupo {
  id_grupo    Int
  id_usuario  Int
  rol         String?   @default("Miembro") @db.VarChar(20)
  fecha_union DateTime? @default(now()) @db.Timestamp()

  grupo       Grupos    @relation(fields: [id_grupo], references: [id_grupo], onDelete: Cascade)
  usuario     Usuarios  @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)

  @@id([id_grupo, id_usuario])
  @@map("miembros_grupo")
}

model Transacciones {
  id_transaccion     Int       @id @default(autoincrement())
  id_grupo           Int
  id_usuario_pagador Int
  monto              Decimal   @db.Decimal(12, 2)
  descripcion        String
  categoria          String?   @default("General")
  comprobante_url    String?
  fecha_gasto        DateTime? @default(now()) @db.Timestamp()
  firma_hmac         String?

  grupo              Grupos    @relation(fields: [id_grupo], references: [id_grupo], onDelete: Cascade)
  pagador            Usuarios  @relation(fields: [id_usuario_pagador], references: [id_usuario])
  participantes      Transaccion_Participantes[]

  @@index([id_grupo])
  @@index([id_usuario_pagador, fecha_gasto])
  @@map("transacciones")
}

model Transaccion_Participantes {
  id_transaccion Int
  id_usuario     Int
  estado_pago    String? @default("Pendiente")

  transaccion    Transacciones @relation(fields: [id_transaccion], references: [id_transaccion], onDelete: Cascade)
  usuario        Usuarios      @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)

  @@id([id_transaccion, id_usuario])
  @@index([id_usuario])
  @@map("transaccion_participantes")
}

model Metodos_Pago {
  id_metodo             Int       @id @default(autoincrement())
  id_usuario            Int
  tarjeta_encriptada    String    @db.Text
  vector_inicializacion String    @db.Text
  fecha_agregado        DateTime? @default(now()) @db.Timestamp()

  usuario               Usuarios  @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)

  @@map("metodos_pago")
}

model Transacciones_Historial {
  id_transaccion     Int       @id
  id_grupo           Int
  id_usuario_pagador Int
  monto              Decimal   @db.Decimal(12, 2)
  descripcion        String
  categoria          String?   @default("General")
  comprobante_url    String?
  fecha_gasto        DateTime  @db.Timestamp()
  firma_hmac         String?
  fecha_archivado    DateTime? @default(now()) @db.Timestamp()

  @@index([id_grupo, fecha_archivado])
  @@index([id_usuario_pagador])
  @@index([fecha_archivado(sort: Desc), id_transaccion(sort: Desc)])
  @@map("transacciones_historial")
}

model Transaccion_Participantes_Historial {
  id_transaccion Int
  id_usuario     Int
  estado_pago    String

  @@id([id_transaccion, id_usuario])
  @@map("transaccion_participantes_historial")
}

model Tokens_Revocados {
  token            String   @id
  fecha_expiracion DateTime @db.Timestamp()

  @@map("tokens_revocados")
}

model Pagos_InApp {
  id_pago             Int       @id @default(autoincrement())
  id_transaccion      Int
  id_usuario_pagador  Int
  id_usuario_receptor Int
  monto_original      Decimal   @db.Decimal(12, 2)
  comision            Decimal   @db.Decimal(12, 2)
  monto_final         Decimal   @db.Decimal(12, 2)
  fecha_pago          DateTime? @default(now()) @db.Timestamp()

  pagador             Usuarios  @relation("Pagador", fields: [id_usuario_pagador], references: [id_usuario])
  receptor            Usuarios  @relation("Receptor", fields: [id_usuario_receptor], references: [id_usuario])

  @@map("pagos_inapp")
}

model Datos_Bancarios {
  id_dato    Int     @id @default(autoincrement())
  id_usuario Int     @unique
  rut        String? @db.Text
  banco      String?
  tipo_cuenta String?
  numero_cuenta String? @db.Text
  correo     String?

  usuario       Usuarios @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)

  @@map("datos_bancarios")
}

model Sesiones_Activas {
  id_sesion       Int       @id @default(autoincrement())
  id_usuario      Int
  token           String    @unique
  dispositivo     String?
  ip              String?
  ultimo_acceso   DateTime  @default(now()) @db.Timestamp()
  creado_en       DateTime  @default(now()) @db.Timestamp()

  usuario         Usuarios  @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)

  @@map("sesiones_activas")
}

model Gastos_Marketing {
  id_gasto    Int       @id @default(autoincrement())
  monto       Decimal   @db.Decimal(12, 2)
  descripcion String
  fecha_gasto DateTime  @default(now()) @db.Timestamp()

  @@map("gastos_marketing")
}