# ==========================================
# Plantilla de Entorno - GroupWallet SaaS
# ==========================================
# Instrucciones: Copia este archivo, renómbralo a ".env" y reemplaza 
# los valores de ejemplo con tus credenciales reales de Producción.

# 1. Base de Datos (Supabase / Prisma)
# La DATABASE_URL usa el puerto 6543 y pgbouncer para el Connection Pooling de la App.
# La DIRECT_URL usa el puerto 5432 para migraciones y npx prisma db push.
DATABASE_URL="postgres://[usuario]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgres://[usuario]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# 2. Seguridad y Criptografía (AES-256 y HMAC)
# JWT_SECRET y HMAC_SECRET pueden ser cualquier cadena alfanumérica larga y aleatoria.
# ENCRYPTION_KEY DEBE SER EXACTAMENTE 64 caracteres hexadecimales (32 bytes).
JWT_SECRET="super_secreto_para_firmar_los_json_web_tokens"
HMAC_SECRET="super_secreto_para_firmar_y_validar_integridad_de_gastos"
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# 3. Entorno de Dominio y Servidor
PORT=3000
NODE_ENV="production"
FRONTEND_URL="https://groupwallettweb.onrender.com" # Cambiar a http://localhost:3000 para local

# 4. Configuración del Cliente Supabase (Para el Frontend JS)
VITE_SUPABASE_URL="https://[tu-identificador].supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGciOiJIUzI1NiIsInR..."

# 5. Notificaciones de Correo Electrónico (Nodemailer / Gmail)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="soporte@tudominio.com"
SMTP_PASS="clave_de_aplicacion_generada_en_google"

# 6. Mensajería SMS y WhatsApp (Twilio)
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_PHONE_NUMBER="+12345678901"
TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"

# 7. Monetización y Pagos (MercadoPago Checkout Pro)
MP_ACCESS_TOKEN="APP_USR-xxxxxxxxxxxxxxxx-xxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxxx"
MP_WEBHOOK_SECRET="tu_webhook_secret_de_mercadopago"

# 8. Almacenamiento de Recibos en la Nube (AWS S3)
AWS_REGION="us-east-1"
AWS_BUCKET_NAME="mi-bucket-groupwallet"
AWS_ACCESS_KEY_ID="AKIAxxxxxxxxxxxxxxxx"
AWS_SECRET_ACCESS_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# 9. Notificaciones Push Web a Celulares (web-push)
VAPID_PUBLIC_KEY="B..."
VAPID_PRIVATE_KEY="..."
VAPID_SUBJECT="mailto:soporte@tudominio.com"